<?xml version="1.0"?>

<robot 
    name="simple_robot" 
    xmlns:xacro="http://www.ros.org/wiki/xacro">

    <link name="base_footprint"/>

    <link name="base_link">
        <visual>
            <origin xyz="0 0 0.1" 
                    rpy="0 0 0"/>

            <geometry>
                <box size="0.4 0.3 0.2"/>
            </geometry>
        </visual>

        <collision>
            <origin xyz="0 0 0.1"
                    rpy="0 0 0"/>
            
            <geometry>
                <box size="0.4 0.3 0.2"/>
            </geometry>
        </collision>

        <inertial>
            <origin xyz="0 0 0.1"
                    rpy="0 0 0"/>
            <mass value="1.0"/>
            <inertia
                ixx="0.0108" ixy="0.0" ixz="0.0"
                iyy="0.0167" iyz="0.0"
                izz="0.0208"/>
        </inertial>
    </link>

    <joint name="base_footprint_to_base_link" type="fixed">
        <parent link="base_footprint"/>
        <child link="base_link"/>
        <origin xyz="0 0 0"
                rpy="0 0 0"/>
    </joint>

    <link name="camera_link">
        <visual>
            <origin xyz="0 0 0"
                    rpy="0 0 0"/>
            <geometry>
                <box size="0.05 0.05 0.05"/>
            </geometry>
        </visual>
    </link>

    <joint name="base_link_to_camera_link" type="fixed">
        <parent link="base_link"/>
        <child link="camera_link"/>
        <origin xyz="0 0 0.3"
                rpy="0 0 0"/>
    </joint>

    <link name="left_wheel_link">
        <visual>
            <origin xyz="0 0.15 -0.05"
                    rpy="1.5708 0 0"/>
            <geometry>
                <cylinder radius="0.05" length="0.03"/>
            </geometry>
            <material name="black">
                <color rgba="0.1 0.1 0.1 1.0"/>
            </material>
        </visual>
    </link>

    <joint name="base_link_to_left_wheel_link"
            type="continuous">
        <parent link="base_link"/>
        <child link="left_wheel_link"/>
        <origin xyz="0 0 0"
                rpy="0 0 0"/>
        <axis xyz="0 1 0"/>
    </joint>

    <link name="right_wheel_link">
        <visual>
            <origin xyz="0 -0.15 -0.05"
                    rpy="1.5708 0 0"/>
            <geometry>
                <cylinder radius="0.05" length="0.03"/>
            </geometry>
            <material name="black">
                <color rgba="0.1 0.1 0.1 1.0"/>
            </material>
        </visual>
    </link>

    <joint name="base_link_to_right_wheel_link"
            type="continuous">
        <parent link="base_link"/>
        <child link="right_wheel_link"/>
        <origin xyz="0 0 0"
                rpy="0 0 0"/>
        <axis xyz="0 1 0"/>
    </joint>
</robot>